-- [Key List]
ScrollingFrame.Parent = MainFrame
ScrollingFrame.Position = UDim2.new(0, 140, 0, 55)
ScrollingFrame.Size = UDim2.new(1, -155, 1, -70)
ScrollingFrame.BackgroundTransparency = 1
ScrollingFrame.ScrollBarThickness = 2
UIListLayout.Parent = ScrollingFrame
UIListLayout.Padding = UDim.new(0, 8)

local function createKeyItem(keyText)
    local KeyBtn = Instance.new("TextButton")
    KeyBtn.Size = UDim2.new(1, -10, 0, 42)
    KeyBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    KeyBtn.Text = ""
    KeyBtn.Parent = ScrollingFrame
    Instance.new("UICorner", KeyBtn).CornerRadius = UDim.new(0, 6)
    local kStroke = Instance.new("UIStroke")
    kStroke.Color = Color3.fromRGB(40, 40, 40)
    kStroke.Parent = KeyBtn

    local key_label = Instance.new("TextLabel")
    key_label.Parent = KeyBtn
    key_label.Size = UDim2.new(1, -10, 1, 0)
    key_label.Position = UDim2.new(0, 10, 0, 0)
    key_label.BackgroundTransparency = 1
    key_label.Font = Enum.Font.Gotham
    key_label.TextSize = 13
    key_label.TextXAlignment = Enum.TextXAlignment.Left
    key_label.RichText = true
    key_label.Text = "<font color='#aaaaaa'>Key:</font> <font color='#00aaff'> " .. keyText .. "</font>"
    
    KeyBtn.MouseEnter:Connect(function()
        TweenService:Create(KeyBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(35, 35, 45)}):Play()
        TweenService:Create(kStroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(0, 170, 255)}):Play()
    end)
    KeyBtn.MouseLeave:Connect(function()
        TweenService:Create(KeyBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(20, 20, 20)}):Play()
        TweenService:Create(kStroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(40, 40, 40)}):Play()
    end)

    KeyBtn.MouseButton1Click:Connect(function()
        setclipboard(keyText)
        key_label.Text = "<font color='#ffffff'>✔ COPIED TO CLIPBOARD</font>"
        TweenService:Create(KeyBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(0, 110, 255)}):Play()
        task.wait(0.5)
        key_label.Text = "<font color='#aaaaaa'>Key:</font> <font color='#00aaff'> " .. keyText .. "</font>"
        TweenService:Create(KeyBtn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(20, 20, 20)}):Play()
    end)
end

local function loadKeys()
    local success, result = pcall(function() return game:HttpGet(KEY_LIST_URL) end)
    if success then
        local count = 0
        for key in string.gmatch(result, "[^\r\n]+") do
            count = count + 1
            createKeyItem(key)
            ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y)
            task.wait(0.05)
        end
        KeyCountLabel.Text = "🔑 Total: " .. count
    else
        KeyCountLabel.Text = "🔑 Fetch Error"
    end
end

ToggleBtn.MouseButton1Click:Connect(function()
    if MainFrame.Visible then
        local closeAnim = TweenService:Create(MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0, 450, 0, 260)})
        closeAnim:Play()
        closeAnim.Completed:Wait()
        MainFrame.Visible = false
    else
        MainFrame.Size = UDim2.new(0, 450, 0, 260)
        MainFrame.Visible = true
        TweenService:Create(MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 480, 0, 280)}):Play()
    end
end)

loadKeys()
                                  
